{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://telemedicinacc.vercel.app/schemas/cvtug-payload.schema.json",
  "title": "CvTUG payload for RehabEasy Transfer API",
  "type": "object",
  "required": ["source", "schema_version", "records"],
  "properties": {
    "source": {
      "const": "cvtug"
    },
    "schema_version": {
      "type": "string",
      "examples": ["1.1"]
    },
    "report_type": {
      "const": "TUG"
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "sender",
          "recipient",
          "created_at",
          "summary",
          "content",
          "patient",
          "assessment"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "sender": {
            "type": "string"
          },
          "recipient": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "summary": {
            "type": "string",
            "description": "Resumo curto para listagem e triagem."
          },
          "content": {
            "type": "string",
            "description": "Narrativa curta legivel por humano. Nao usar este campo para guardar estatisticas detalhadas."
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_document": {
            "type": "object",
            "properties": {
              "file_name": {
                "type": "string"
              },
              "pages": {
                "type": "integer"
              },
              "document_type": {
                "type": "string"
              },
              "report_timestamp_text": {
                "type": "string"
              },
              "file_name_timestamp_text": {
                "type": ["string", "null"]
              },
              "notes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "raw_report_text": {
            "type": "string",
            "description": "Texto integral extraido do PDF para auditoria e reprocessamento."
          },
          "patient": {
            "type": "object",
            "required": ["name", "age_years", "sex", "external_id"],
            "properties": {
              "name": {
                "type": "string"
              },
              "age_years": {
                "type": "integer"
              },
              "sex": {
                "type": "string"
              },
              "external_id": {
                "type": "string"
              }
            }
          },
          "assessment": {
            "type": "object",
            "required": ["performed_at", "measure_unit", "conditions", "automated_flags"],
            "properties": {
              "performed_at": {
                "type": "string",
                "format": "date-time"
              },
              "measure_unit": {
                "const": "seconds"
              },
              "conditions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["code", "label", "total_seconds", "phases"],
                  "properties": {
                    "code": {
                      "type": "string",
                      "enum": ["normal", "motor", "cognitive"]
                    },
                    "label": {
                      "type": "string"
                    },
                    "total_seconds": {
                      "type": "number"
                    },
                    "dual_task_cost_percent": {
                      "type": ["number", "null"]
                    },
                    "reference": {
                      "type": ["object", "null"],
                      "properties": {
                        "expected_seconds": {
                          "type": "number"
                        },
                        "upper_limit_seconds": {
                          "type": "number"
                        },
                        "source": {
                          "type": "string"
                        }
                      }
                    },
                    "phases": {
                      "type": "object",
                      "required": ["stand_seconds", "walk_seconds", "sit_seconds"],
                      "properties": {
                        "stand_seconds": {
                          "type": "number"
                        },
                        "walk_seconds": {
                          "type": "number"
                        },
                        "sit_seconds": {
                          "type": "number"
                        }
                      }
                    }
                  }
                }
              },
              "derived_metrics": {
                "type": "object",
                "properties": {
                  "worst_dual_task_cost_percent": {
                    "type": "number"
                  },
                  "normal_walk_speed_mps": {
                    "type": "number"
                  }
                }
              },
              "automated_flags": {
                "type": "object",
                "properties": {
                  "tug_above_upper_limit": {
                    "type": "boolean"
                  },
                  "fall_screening": {
                    "type": "object",
                    "properties": {
                      "status": {
                        "type": "string"
                      },
                      "thresholds": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "seconds": {
                              "type": "number"
                            },
                            "source": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  },
                  "dual_task_cost": {
                    "type": "object",
                    "properties": {
                      "status": {
                        "type": "string"
                      },
                      "alert_threshold_percent": {
                        "type": "number"
                      },
                      "worst_condition_code": {
                        "type": "string"
                      },
                      "worst_percent": {
                        "type": "number"
                      }
                    }
                  },
                  "gait_speed": {
                    "type": "object",
                    "properties": {
                      "normal_condition_mps": {
                        "type": "number"
                      },
                      "note": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "methodology_notes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
